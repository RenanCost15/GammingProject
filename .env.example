# Desenvolvimento local: copie este arquivo para .env.local e informe a chave da RAWG.
# Publicação no GitHub Pages: cadastre este mesmo valor no Secret
# NEXT_PUBLIC_RAWG_API_KEY em Settings > Secrets and variables > Actions.
#
# Observação: em uma aplicação estática no GitHub Pages, variáveis NEXT_PUBLIC_
# são incorporadas ao JavaScript enviado ao navegador. Não use uma chave sensível
# ou associada a cobrança sem um backend/proxy próprio.
NEXT_PUBLIC_RAWG_API_KEY=coloque_sua_chave_da_rawg_aqui

# Deixe vazio no desenvolvimento local. O GitHub Actions define /GammingProject.
NEXT_PUBLIC_BASE_PATH=
